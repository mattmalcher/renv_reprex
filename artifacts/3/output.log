> check_url_curl <- function(url, timeout_s = 10) {
+     args <- c("-s", "-o", "/dev/null", "-w", "%{http_code}", 
+         "--connect-timeout", as.character(timeout_s), "--max-time", 
+         as.character(timeout_s), url)
+     result <- tryCatch({
+         code <- as.integer(system2("curl", args, stdout = TRUE, 
+             stderr = FALSE))
+         if (!is.na(code) && code > 0) 
+             paste0("reachable (HTTP ", code, ")")
+         else "blocked: no HTTP response"
+     }, error = function(e) paste0("error: ", conditionMessage(e)))
+     result
+ }

