> classify <- function(msg, warns) {
+     hay <- tolower(paste(c(msg, warns), collapse = " "))
+     if (grepl("biocversion", hay)) 
+         "BiocVersion dependency not available"
+     else if (grepl("cannot be validated", hay)) 
+         "Bioconductor version validation failed"
+     else if (grepl("failed to download|not available", hay)) 
+         "Dependency download failed"
+     else if (nzchar(hay)) 
+         hay
+     else NA
+ }

> write_json(list(operation = "renv::install()", result = if (is.null(install_error)) "ok (but dependency missing)" else paste0("error: ", 
